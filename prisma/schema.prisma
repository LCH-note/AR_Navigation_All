generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Facility {
  id                Int          @id @default(autoincrement())
  name              String
  type              FacilityType @default(indoor)
  centerLat         Float?
  centerLng         Float?
  description       String?      @db.Text
  currentMapAssetId Int?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  mapAssets  MapAsset[]
  anchors    Anchor[]
  places     Place[]
  graphNodes GraphNode[]
  graphEdges GraphEdge[]

  @@map("facilities")
}

enum FacilityType {
  indoor
  outdoor
  hybrid
}

model MapAsset {
  id         Int          @id @default(autoincrement())
  facilityId Int
  kind       MapAssetKind @default(assetbundle)
  filePath   String
  fileUrl    String?
  version    Int          @default(1)
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
  @@map("map_assets")
}

enum MapAssetKind {
  assetbundle
  glb
  obj
  fbx
}

model Anchor {
  id         Int @id @default(autoincrement())
  facilityId Int

  cloudAnchorId String

  localX      Float
  localY      Float
  localZ      Float
  localYawDeg Float?

  floor Int?
  label String?
  note  String?

  createdAt DateTime @default(now())

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  places Place[]

  @@unique([facilityId, cloudAnchorId])
  @@index([facilityId])
  @@map("anchors")
}

model Place {
  id          Int     @id @default(autoincrement())
  facilityId  Int
  name        String
  description String? @db.Text

  feature    String?
  imagePath  String?
  arMarkerId String?

  coordType CoordType @default(LOCAL_3D)

  x        Float?
  y        Float?
  z        Float?
  floor    Int?
  anchorId Int?

  lat Float?
  lng Float?

  nearestNodeId Int?

  category String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  anchor   Anchor?  @relation(fields: [anchorId], references: [id], onDelete: SetNull)

  reviews Review[]

  @@index([category])
  @@index([facilityId])
  @@index([anchorId])
  @@index([arMarkerId])
  @@map("places")
}

model Review {
  id        Int      @id @default(autoincrement())
  placeId   Int
  star      Int
  content   String?  @db.Text
  nickname  String   @default("익명")
  createdAt DateTime @default(now())

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@map("reviews")
}

enum CoordType {
  LOCAL_3D
  GPS
}

model GraphNode {
  id         Int           @id @default(autoincrement())
  facilityId Int
  x          Float
  y          Float
  z          Float
  floor      Int?
  type       GraphNodeType
  label      String?
  createdAt  DateTime      @default(now())

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
  @@map("graph_nodes")
}

enum GraphNodeType {
  corridor
  stairs
  elevator
  poi
  entrance
}

model GraphEdge {
  id            Int            @id @default(autoincrement())
  facilityId    Int
  fromNodeId    Int
  toNodeId      Int
  weight        Float?
  kind          GraphEdgeKind?
  bidirectional Boolean        @default(true)
  createdAt     DateTime       @default(now())

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@map("graph_edges")
}

enum GraphEdgeKind {
  walk
  stairs
  elevator
}