# ==========================================
# Unity .gitignore
# AR_Navigator 프로젝트용
# ==========================================

# ------------------------------------------
# [Unity 자동 생성 폴더]
# 빌드, 캐시, 임시 파일 등 자동 생성되므로 제외
# ------------------------------------------
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# ------------------------------------------
# [MemoryCaptures]
# Unity Profiler 메모리 캡처 파일
# ------------------------------------------
[Mm]emoryCaptures/

# ------------------------------------------
# [Asset Store 도구]
# Asset Store에서 가져온 에셋 임시 파일
# ------------------------------------------
[Aa]sset [Ss]tore [Tt]ools/

# ------------------------------------------
# [빌드 결과물]
# 실제 빌드된 앱 파일들 (Android APK, iOS Xcode 프로젝트 등)
# ------------------------------------------
*.apk
*.aab
*.unitypackage
*.app

# ------------------------------------------
# [Visual Studio / Rider IDE 파일]
# IDE가 자동 생성하는 프로젝트/솔루션 파일
# (Unity가 직접 재생성하므로 불필요)
# ------------------------------------------
.vs/
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ------------------------------------------
# [OS 시스템 파일]
# Windows / macOS 운영체제가 자동 생성하는 파일
# ------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ------------------------------------------
# [JetBrains Rider]
# Rider IDE 설정 폴더
# ------------------------------------------
.idea/

# ------------------------------------------
# [Crashlytics]
# Firebase Crashlytics 자동 생성 파일
# ------------------------------------------
crashlytics-build.properties

# ------------------------------------------
# [Android 빌드 관련]
# Android 빌드 시 생성되는 로컬 설정 파일
# ------------------------------------------
local.properties
*.keystore

# ------------------------------------------
# [Burst 컴파일러 캐시]
# Unity Burst 컴파일러가 생성하는 캐시
# ------------------------------------------
BurstDebugInformation_DoNotShip/

# ------------------------------------------
# [TextMeshPro 자동 생성]
# TMP 에셋 사용 시 자동 생성되는 폰트 에셋
# (원본 폰트 파일만 버전 관리하면 충분)
# ------------------------------------------
Assets/TextMesh\ Pro/Examples\ &\ Extras/

# ------------------------------------------
# [MCP (Model Context Protocol) 로그]
# MCPForUnity 도구 실행 중 생성되는 로그 파일
# ------------------------------------------
Assets/MCPForUnity/Editor/node_modules/
Assets/MCPForUnity/Editor/*.log

# ------------------------------------------
# [기타 에디터/툴 파일]
# ------------------------------------------
nuget.config

# ==========================================
# MCPForUnity 도구 관련 파일 제외
# ========================================= 
Assets/MCPForUnity/

# ==========================================
# claude 관련 파일 제외
# ==========================================
.claude/
CLAUDE.md
